# --- DuckDB ----------------------------------------------------------------
VANTAGE_DUCKDB_PATH=vantage.duckdb

# --- SEC EDGAR -------------------------------------------------------------
# SEC requires a contact in the User-Agent for all programmatic requests.
SEC_USER_AGENT="VANTAGE Research contact@example.com"

# --- Anthropic / Claude ----------------------------------------------------
ANTHROPIC_API_KEY=
VANTAGE_MODEL_DRAFT=claude-opus-4-7
VANTAGE_MODEL_CLASSIFY=claude-haiku-4-5-20251001

# --- News / RSS sources (optional) -----------------------------------------
# Comma-separated feed URLs; ingest/news.py reads these.
VANTAGE_RSS_FEEDS=

# --- Alerts (optional, Phase 7) --------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
