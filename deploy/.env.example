# Copy to deploy/.env and fill in. Never commit the real .env.

# FRED API key (free): https://fredaccount.stlouisfed.org/apikey
# Required for indicator ingestion. Without it, indicators are skipped but the
# equity index still builds.
FRED_API_KEY=

# Host port the terminal is served on (mapped to Streamlit's 8501 in-container).
WEB_PORT=80

# Hour of day (UTC, 0-23) the scheduler runs the daily refresh.
REFRESH_HOUR_UTC=6

# Set to 1 to force a refresh every time the scheduler container starts.
# Default behaviour: refresh on start only if the store is empty.
REFRESH_ON_START=0

# Optional single-password gate for the dashboard. Leave blank to disable.
VANTAGE_DASHBOARD_PASSWORD=

# Optional Slack or Discord incoming-webhook URL. When set, the scheduler posts
# a message if the daily refresh fails or crashes. Leave blank to disable.
VANTAGE_ALERT_WEBHOOK=
